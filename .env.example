# Database
DATABASE_URL=postgresql://sidekick:sidekick@localhost:5432/sidekick

# Object storage
# Set to MinIO endpoint for local dev; unset entirely in production (uses real S3)
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=artifacts

# OpenAI — used for embeddings (text-embedding-3-small) and LLM calls
OPENAI_API_KEY=sk-...
